{
  "name": "soan-professional-cli",
  "version": "1.2.2",
  "description": "Professional CLI for Soan image generation",
  "homepage": "https://github.com/Kotomiya07/soan-professional#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kotomiya07/soan-professional.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Kotomiya07/soan-professional/issues"
  },
  "author": "Center for Open Data in the Humanities, Research Organization of Information and Systems",
  "contributors": [
    "Jun HOMMA (https://www.flxstyle.com/)"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p ../core/tsconfig.json --noEmit",
    "lint": "eslint src test --max-warnings=0",
    "format:check": "prettier --check \"../../{README.md,README.ja.md,.github/workflows/*.yml,.prettierrc.json}\" \"{README.md,package.json,tsconfig*.json,eslint.config.js,src/**/*.ts,test/**/*.{ts,mjs}}\"",
    "format": "prettier --write \"../../{README.md,README.ja.md,.github/workflows/*.yml,.prettierrc.json}\" \"{README.md,package.json,tsconfig*.json,eslint.config.js,src/**/*.ts,test/**/*.{ts,mjs}}\"",
    "test": "vitest run",
    "smoke": "node dist/cli.js --text \"［加］/な\" --seed 42 --gamma 1.1 --generated-at 2026-06-29T00:00:00.000Z --output ./tmp/smoke.jpg --metadata-output ./tmp/smoke.json --force",
    "test:e2e": "node test/cli-e2e.mjs",
    "check:mecab:nix": "nix shell nixpkgs#mecab -c bash -lc 'SOAN_MECAB_COMMAND=\"$(command -v mecab)\" npm run test:e2e'",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run check:mecab:nix && npm run smoke",
    "prepack": "npm run build && node scripts/pack-manifest.mjs prepare",
    "postpack": "node scripts/pack-manifest.mjs restore"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.100",
    "jquery": "^3.7.0",
    "jsdom": "^22.1.0",
    "kuromoji": "^0.1.2",
    "minus-h": "^1.1.1"
  },
  "optionalDependencies": {
    "@napi-rs/canvas-android-arm64": "0.1.100",
    "@napi-rs/canvas-darwin-arm64": "0.1.100",
    "@napi-rs/canvas-darwin-x64": "0.1.100",
    "@napi-rs/canvas-linux-arm-gnueabihf": "0.1.100",
    "@napi-rs/canvas-linux-arm64-gnu": "0.1.100",
    "@napi-rs/canvas-linux-arm64-musl": "0.1.100",
    "@napi-rs/canvas-linux-riscv64-gnu": "0.1.100",
    "@napi-rs/canvas-linux-x64-gnu": "0.1.100",
    "@napi-rs/canvas-linux-x64-musl": "0.1.100",
    "@napi-rs/canvas-win32-arm64-msvc": "0.1.100",
    "@napi-rs/canvas-win32-x64-msvc": "0.1.100"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "soan": "file:../legacy-soan",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "bin": {
    "soan": "dist/cli.js",
    "soan-cli": "dist/cli.js",
    "soan-pro": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "vendor",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "soan",
    "kuzushiji",
    "cli",
    "typography",
    "japanese"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  }
}
